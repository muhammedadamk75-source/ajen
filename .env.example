# ── LLM Providers (at least one required) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Ollama (local models, optional) ───────────────────────────
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# ── Workspace ─────────────────────────────────────────────────
WORKSPACE_DIR=./workspaces
MANIFESTS_DIR=./employee-manifests

# ── Logging ───────────────────────────────────────────────────
RUST_LOG=info

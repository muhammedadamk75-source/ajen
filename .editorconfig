root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.rs]
indent_style = space
indent_size = 4

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.toml]
indent_style = space
indent_size = 4

[Dockerfile]
indent_style = space
indent_size = 4

[docker-compose.yml]
indent_style = space
indent_size = 2
